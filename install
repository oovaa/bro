#!/bin/bash

GREEN='\033[0;32m'
RED='\033[0;31m'
NC='\033[0m'

CONFIG_FILE="$HOME/.bro_config"
INSTALL_DIR="$HOME/.local/share/bro"
BIN_DIR="$HOME/.local/bin"

echo -e "${GREEN}Installing Bro (via uv)...${NC}"

# 1. Check for uv
if ! command -v uv &> /dev/null; then
    echo -e "${RED}Error: 'uv' is not installed.${NC}"
    echo "Install it with: curl -LsSf https://astral.sh/uv/install.sh | sh"
    exit 1
fi

# 2. Setup Virtual Env (using uv)
echo "Setting up virtual environment in $INSTALL_DIR..."
rm -rf "$INSTALL_DIR"
mkdir -p "$INSTALL_DIR"

# Copy source files first
cp -r bro "$INSTALL_DIR/"
cp pyproject.toml "$INSTALL_DIR/"

# Create venv specifically at the install path
uv venv "$INSTALL_DIR/venv" --python 3.11

# 3. Install Dependencies (using uv pip)
echo "Installing dependencies..."
# We point uv to the specific environment we just created
source "$INSTALL_DIR/venv/bin/activate"
uv pip install -e "$INSTALL_DIR"

# 4. Setup Executable Wrapper
echo "Creating executable..."
mkdir -p "$BIN_DIR"

cat <<EOF > "$BIN_DIR/bro"
#!/bin/bash
source "$INSTALL_DIR/venv/bin/activate"
python -m bro.main "\$@"
EOF

chmod +x "$BIN_DIR/bro"

# 5. Handle API Key
API_KEY=$1

if [ -z "$API_KEY" ]; then
    if [ -f "$CONFIG_FILE" ]; then
        echo "Using existing configuration."
    else
        echo -e "${RED}Please provide your GROQ_API_KEY as an argument.${NC}"
        echo "Usage: ./install <GROQ_API_KEY>"
        exit 1
    fi
else
    echo "GROQ_API_KEY=$API_KEY" > "$CONFIG_FILE"
    echo "USER_AGENT=BroAgent/1.0" >> "$CONFIG_FILE"
    echo -e "${GREEN}API Key saved to $CONFIG_FILE${NC}"
fi

# 6. Add to Path
if [[ ":$PATH:" != *":$BIN_DIR:"* ]]; then
    SHELL_RC=""
    if [[ $SHELL == */zsh ]]; then SHELL_RC="$HOME/.zshrc"; 
    elif [[ $SHELL == */bash ]]; then SHELL_RC="$HOME/.bashrc"; fi
    
    if [ -n "$SHELL_RC" ]; then
        echo "export PATH=\"$BIN_DIR:\$PATH\"" >> "$SHELL_RC"
        echo -e "${GREEN}Added $BIN_DIR to PATH. Restart shell or run 'source $SHELL_RC'${NC}"
    fi
fi

echo -e "${GREEN}Bro installed successfully! 🚀${NC}"