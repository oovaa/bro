#!/bin/bash

# Define color variables
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Configuration
exec_link_path="/usr/local/bin"
env_file="/etc/environment"

# Check for required commands
check_command() {
    if ! command -v $1 &>/dev/null; then
        echo -e "${RED}$1 is required but not installed.${NC}"
        exit 1
    fi
}

check_command "bun"
check_command "sudo"

# Check if bro script exists
if [ ! -f bro ]; then
    echo -e "${RED}The bro script does not exist in the current directory.${NC}"
    exit 1
fi

# Set executable permission
chmod +x bro
echo -e "${GREEN}Made bro executable ✅${NC}"

# Install dependencies
echo -e "${GREEN}Installing dependencies...${NC}"
if bun install; then
    echo -e "${GREEN}Dependencies installed ✅${NC}"
else
    echo -e "${RED}Failed to install dependencies${NC}"
    exit 1
fi

# Create symbolic link
echo -e "${GREEN}Creating system-wide symlink...${NC}"
if sudo ln -sf "$(pwd)/bro" "$exec_link_path/bro"; then
    echo -e "${GREEN}Symlink created in $exec_link_path ✅${NC}"
else
    echo -e "${RED}Failed to create symlink${NC}"
    exit 1
fi

# Handle API key
if [ $# -eq 1 ]; then
    echo -e "${GREEN}Setting DEEPSEEK_API_KEY in $env_file${NC}"

    # Backup environment file
    sudo cp "$env_file" "$env_file.bak"

    # Update or add API key
    if grep -q "DEEPSEEK_API_KEY=" "$env_file"; then
        sudo sed -i "s/DEEPSEEK_API_KEY=.*/DEEPSEEK_API_KEY=\"$1\"/" "$env_file"
    else
        echo "DEEPSEEK_API_KEY=\"$1\"" | sudo tee -a "$env_file" >/dev/null
    fi

    # Apply changes
    export DEEPSEEK_API_KEY="$1"
    echo -e "${YELLOW}Note: You may need to restart your session for system-wide availability${NC}"
else
    echo -e "${YELLOW}No API key provided. Set DEEPSEEK_API_KEY in $env_file manually${NC}"
fi

echo -e "\n${GREEN}Installation complete! Run 'bro' to start.${NC}"
