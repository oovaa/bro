#!/usr/bin/env bash

# Define color codes
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

exec_link_path="/usr/local/bin"
env_file="/etc/environment"

# Function to print messages
print_message() {
    local color=$1
    local message=$2
    echo -e "${color}${message}${NC}"
}

# Remove symbolic link
remove_symlink() {
    if [ -L "$exec_link_path/bro" ]; then
        if sudo rm "$exec_link_path/bro"; then
            print_message "$GREEN" "bro has been successfully removed from the system's path ✅"
        else
            print_message "$RED" "Failed to remove bro from the system's path."
        fi
    else
        print_message "$YELLOW" "bro is not installed in the system's path."
    fi
}

# Remove DEEPSEEK_API_KEY from system environment
remove_api_key() {
    if [ -f "$env_file" ]; then
        if grep -q "DEEPSEEK_API_KEY=" "$env_file"; then
            sudo sed -i "/DEEPSEEK_API_KEY=/d" "$env_file"
            print_message "$GREEN" "DEEPSEEK_API_KEY has been removed from system environment ✅"
        else
            print_message "$YELLOW" "DEEPSEEK_API_KEY not found in system environment."
        fi
    else
        print_message "$RED" "System environment file $env_file does not exist."
    fi
}

# Remove node_modules folder
remove_node_modules() {
    if [ -d "node_modules" ]; then
        rm -rf node_modules
        print_message "$GREEN" "node_modules folder has been removed ✅"
    else
        print_message "$YELLOW" "node_modules folder does not exist."
    fi
}

# Remove bun.lockb file
remove_bun_lockb() {
    if [ -f "bun.lockb" ]; then
        rm bun.lockb
        print_message "$GREEN" "bun.lockb file has been removed ✅"
    else
        print_message "$YELLOW" "bun.lockb file does not exist."
    fi
}

# Main script execution
remove_symlink
remove_api_key
remove_node_modules
remove_bun_lockb

echo -e "\n${GREEN}Uninstallation complete!${NC}"
